# ============================================================
# MINERVA Deal Engine — Variables de entorno
# ============================================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repo. .env.example sí puede subirse.
# ============================================================

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-...

# ---------- Supabase (frontend, públicas) ----------
VITE_SUPABASE_URL=https://tohfuokcngavbmbjsdru.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ---------- Supabase (backend, PRIVADA — solo Railway) ----------
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- Flow (Chile) ----------
# Modo sandbox: https://sandbox.flow.cl/api
# Modo prod:    https://www.flow.cl/api
FLOW_API_KEY=...
FLOW_SECRET_KEY=...
FLOW_BASE_URL=https://www.flow.cl/api
FLOW_WEBHOOK_SECRET=...

# ---------- Resend (email transaccional) ----------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=cuenta@minervadeal.com
RESEND_FROM_NAME=MINERVA
RESEND_REPLY_TO=soporte@minervadeal.com

# ---------- App ----------
APP_BASE_URL=https://www.minervadeal.com
PORT=3000

# ---------- Cron jobs ----------
# Secret arbitrario que protege /api/jobs/send-reminders
CRON_SECRET=cambia-este-valor-por-uno-largo-y-aleatorio
